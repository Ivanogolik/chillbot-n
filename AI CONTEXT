kd->dispatchKeyboardMSG(cocos2d::enumKeyCodes::KEY_Space, true, false, 0.0);

// Метод 8 — симуляция стрелки вверх:
kd->dispatchKeyboardMSG(cocos2d::enumKeyCodes::KEY_Up, true, false, 0.0);
