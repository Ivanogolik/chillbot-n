// Метод 3 — через базовый класс:
static_cast<GJBaseGameLayer*>(playLayer)->handleButton(true, 1, true);

// Метод 4 — buffered input:
static_cast<GJBaseGameLayer*>(playLayer)->queueButton(1, true, false, 0.0);

