## 🚫 БЛОКИРОВКА ВВОДА ИГРОКА

```cpp
static bool g_simulatingKey = false;  // флаг чтобы не блокировать собственные нажатия

class $modify(MyKD, cocos2d::CCKeyboardDispatcher) {
    bool dispatchKeyboardMSG(enumKeyCodes key, bool down, bool repeat, double delta) {
        if (g_bot.active && g_bot.blockPlayerInput && !g_simulatingKey) {
            if (key == KEY_Space || key == KEY_Up || key == KEY_W) {
                return true;  // НЕ передаём в игру
            }
        }
        return cocos2d::CCKeyboardDispatcher::dispatchKeyboardMSG(key, down, repeat, delta);
    }
};

// В executeJump():
g_simulatingKey = true;   // флаг ВКЛ перед симуляцией
g_bot.executeJump(this);
g_simulatingKey = false;  // флаг ВЫКЛ после
```

