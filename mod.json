{
    "geode": "5.6.1",
    "gd": {
        "win": "2.2081",
        "android": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },
    "version": "v1.0.0",
    "id": "ivanogolik.chillbot",
    "name": "chillbot",
    "developer": "Ivanogolik",
    "description": "AI bot that learns to play levels and saves macros (zBot/Eclipse-like).",
    "tags": ["gameplay", "utility"],
    "dependencies": {
        {
            "id": "geode.custom-keybinds",
            "version": ">=2.0.0",
            "importance": "recommended"
        },
        {
            "id": "geode.devtools",
            "version": ">=1.0.0",
            "importance": "suggested"
        }
},
    "settings": {
        "recording-enabled": {
            "type": "bool",
            "default": true,
            "name": "Record successful runs",
            "description": "Save best progress to chillbot_macro.gdai"
        },
        "playback-mode": {
            "type": "bool",
            "default": false,
            "name": "Playback best macro",
            "description": "Replay saved best run instead of learning"
        }
    }
}
