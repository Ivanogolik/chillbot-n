{
    "geode": "5.6.1",
    "gd": {
        "win": "2.2081",
        "android64": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },
    "id": "chillbotuwu",
    "name": "chillbot",
    "version": "v1.0.0",
    "developer": "Ivanogolik",
    "description": "Обучающийся ИИ бот для прохождения уровней. Сохраняет реплеи .gdr2",
    "repository": "https://github.com/yourname/gd-ai-bot",
    
    "dependencies": [
        {
            "id": "maxnut.gd-replay-format",
            "version": ">=v1.1.0",
            "importance": "required"
        },
        {
            "id": "geode.node-ids",
            "version": ">=v1.22.0",
            "importance": "suggested"
        },
        {
            "id": "geode.custom-keybinds",
            "version": ">=v2.1.0",
            "importance": "suggested"
        },
        {
            "id": "hjfod.betteredit",
            "version": ">=v4.0.0",
            "importance": "suggested"
        },
        {
            "id": "geode.devtools",
            "version": ">=v1.12.0",
            "importance": "suggested"
        }
    ],

    "settings": {
        "ai-enabled": {
            "name": "Включен",
            "description": "Глобальное состояние ИИ",
            "type": "bool",
            "default": false
        },
        "learning-rate": {
            "name": "Скорость обучения",
            "type": "float",
            "default": 0.15,
            "min": 0.01,
            "max": 0.5
        },
        "save-replays": {
            "name": "Сохранять реплеи",
            "description": "Автосохранение лучших прохождений в .gdr2",
            "type": "bool",
            "default": true
        },
        "toggle-key": {
            "name": "Тоггл ИИ",
            "description": "Быстрое включение/выключение",
            "type": "keybind",
            "default": "F5"
        }
    },

    "resources": {
        "files": [
            "resources/*"
        ]
    }
}
